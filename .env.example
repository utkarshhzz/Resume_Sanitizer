APP_ENV=development
APP_VERSION=1.0.0
LOG_LEVEL=DEBUG

# Fast API
API_PREFIX=/api/v1
MAX_UPLOAD_SIZE_MB=20
REQUEST_TIMEOUT_SECONDS=30

# Redis configuration 
CACHE_BACKEND=memory
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

# Rate limits
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
