# ╔════════════════════════════════════════════════════════════╗
# ║  Resume Sanitizer — Environment Configuration             ║
# ║  Copy this file to .env and modify values as needed        ║
# ╚════════════════════════════════════════════════════════════╝

# --- Application ---
APP_ENV=development                # "development" | "staging" | "production"
APP_VERSION=1.0.0
LOG_LEVEL=DEBUG                    # DEBUG | INFO | WARNING | ERROR

# --- API Configuration ---
API_PREFIX=/api/v1
MAX_UPLOAD_SIZE_MB=20              # Reject files larger than this (in megabytes)
REQUEST_TIMEOUT_SECONDS=30
CORS_ORIGINS=["*"]                 # JSON array of allowed origins

# --- OCR Configuration ---
# These control the fallback OCR engine for scanned/image-based PDFs
OCR_CHAR_THRESHOLD=50              # If total extracted chars < this, trigger OCR
OCR_DPI=300                        # Higher = more accurate but slower
OCR_LANGUAGE=eng                   # Tesseract language pack
OCR_CONFIDENCE_THRESHOLD=40        # Min word confidence (0-100) to include

# --- NLP / PII Detection ---
SPACY_MODEL=en_core_web_lg         # spaCy model name (must be installed)
USE_ONNX_NER=false                 # Set true to use ONNX model (not yet implemented)
ONNX_MODEL_PATH=models/ner_model.onnx

# --- Cache Configuration ---
CACHE_BACKEND=memory               # "memory" (dev) | "redis" (production)
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600             # Cache duration in seconds (1 hour)

# --- Rate Limiting ---
RATE_LIMIT_REQUESTS=100            # Max requests per window per IP
RATE_LIMIT_WINDOW_SECONDS=60       # Window duration in seconds

# --- Redaction Styling ---
# RGB values from 0.0 to 1.0. White = invisible redaction.
# REDACTION_FILL_COLOR=(1.0, 1.0, 1.0)
# REDACTION_PADDING_PX=2
